{
  "providers": {
    "primary": {
      "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
      "api": "google-genai",
      "models": [
        {
          "id": "gemini-3-flash",
          "name": "Gemini 3 Flash",
          "reasoning": false,
          "input": ["text", "image"],
          "contextWindow": 1048576,
          "maxTokens": 65536
        }
      ]
    },
    "fallback": {
      "baseUrl": "https://api.anthropic.com/v1",
      "api": "anthropic-messages",
      "models": [
        {
          "id": "claude-opus-4-6-thinking",
          "name": "Claude Opus 4.6 Thinking",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 200000,
          "maxTokens": 32000
        }
      ]
    },
    "local": {
      "baseUrl": "http://localhost:11434/v1",
      "api": "openai-completions",
      "models": [
        {
          "id": "qwen2.5:latest",
          "name": "Qwen 2.5 (Local)",
          "reasoning": false,
          "input": ["text"],
          "contextWindow": 32768,
          "maxTokens": 8192
        }
      ]
    }
  },
  "routing": {
    "strategy": "cost-optimized",
    "rules": [
      "Use primary (Gemini) for routine tasks",
      "Fallback to Claude for complex reasoning",
      "Local Ollama for offline/privacy-sensitive ops"
    ]
  }
}
